# SEO / Site (for @nuxtjs/seo - sitemap, robots, meta)
NUXT_SITE_URL=https://example.com
NUXT_SITE_NAME=My App
NUXT_SITE_DESCRIPTION=My app description

# API — AutoForge Gateway (proxies orgs, questions, etc.)
NUXT_PUBLIC_API_BASE=http://localhost:8000
# Auth service: leave unset to use same-origin proxy; set for direct URL (e.g. prod)
# NUXT_PUBLIC_AUTH_API_BASE=http://localhost:8001
NUXT_PUBLIC_SAMPLE_API_BASE=https://jsonplaceholder.typicode.com
# Organization GraphQL (via gateway)
NUXT_PUBLIC_GRAPHQL_ENDPOINT=http://localhost:8000/api/v1/organizations/graphql
NUXT_API_SECRET=your-secret-key

# Auth
JWT_SECRET=your-jwt-secret

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/db

# AWS (optional)
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=
AWS_S3_BUCKET=
